# TokenForge - Configuration
# Ces variables peuvent être utilisées pour pré-configurer les clés API
# (optionnel - les clés peuvent aussi être configurées depuis l'interface)

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Port du backend (défaut: 8765)
BACKEND_PORT=8765

# TokenForge v2 — Intelligence Platform
DATABASE_URL=tokenforge_v2.db
REDIS_URL=
QDRANT_URL=http://localhost:6333
JWT_SECRET=change-me-in-production
DEFAULT_TENANT_ID=default
OTEL_ENABLED=0
PROMETHEUS_ENABLED=1
FORGE_COMPRESSION_PROFILE=industrial
FORGE_TARGET_URL=https://api.openai.com
